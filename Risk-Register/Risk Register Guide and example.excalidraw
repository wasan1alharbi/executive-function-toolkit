    {
      "id": "qgIYNvvq_hso12Rppo8f5",
      "type": "text",
      "x": -1325.9862174643222,
      "y": 4327.552534880196,
      "width": 1489.119873046875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
