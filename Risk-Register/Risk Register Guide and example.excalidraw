      "link": null,
      "locked": false,
      "text": "An Assessor agent runs once a day and reviews each company agent's recent activity and statements against its declared identity, pulling persona drift\nback without rewriting the agent's memory stream",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "ChFzNkcfz7BoRghuTa4tM",
      "originalText": "An Assessor agent runs once a day and reviews each company agent's recent activity and statements against its declared identity, pulling persona drift back without rewriting the agent's memory stream",
      "autoResize": true,
      "lineHeight": 1.25
    },
