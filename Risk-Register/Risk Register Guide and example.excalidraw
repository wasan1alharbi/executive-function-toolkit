      "link": null,
      "locked": false,
      "text": "Initial KPI values are pulled from real company data rather than invented by the LLM, and per-question score changes are bounded to a fixed range, so\nthe scores stay anchored to evidence instead of drifting on model judgement alone",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "bTTmmioZDNkXOLlKh1jw4",
