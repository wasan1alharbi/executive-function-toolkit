      "type": "text",
      "x": -2700.316769929047,
      "y": 3625.6212459327676,
      "width": 759.6280477924216,
      "height": 383.44172479411134,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffffff",
