      "seed": 45991380,
      "version": 338,
      "versionNonce": 199308268,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1778972094968,
      "link": null,
      "locked": false,
      "text": "Agent identity generation\nhappens after this step",
      "fontSize": 98.28843186745948,
