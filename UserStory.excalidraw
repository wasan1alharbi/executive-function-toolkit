    {
      "id": "7Ky7BYB6Lp3h7xwo2IgQA",
      "type": "text",
      "x": -1325.9862174643222,
      "y": 4143.90827999179,
      "width": 1490.980224609375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
