      "seed": 1125975390,
      "version": 105,
      "versionNonce": 358546132,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1778970862458,
      "link": null,
      "locked": false,
      "text": "Wikipedia is treated as a hard dependency, with no fail-over or caching around it or the other third-party calls. If any of them go down mid-session,\nnew submissions can't be grounded against external evidence. This residual exposure is accepted given the project's scope, and fail-open wrappers are\nflagged for Future Work (ch8)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "CeCR3uHxRhJOle-ykqnga",
      "originalText": "Wikipedia is treated as a hard dependency, with no fail-over or caching around it or the other third-party calls. If any of them go down mid-session, new submissions can't be grounded against external evidence. This residual exposure is accepted given the project's scope, and fail-open wrappers are flagged for Future Work (ch8)",
      "autoResize": true,
      "lineHeight": 1.25
    },
