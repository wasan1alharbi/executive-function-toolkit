    {
      "id": "1yexZpOs2M5YUMLtGmOuM",
      "type": "text",
      "x": 5867.930957293496,
      "y": 3770.765836309082,
      "width": 1490.980224609375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
