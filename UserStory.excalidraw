    {
      "id": "7Ni7-TEQxN09-irB0AqTM",
      "type": "text",
      "x": 5867.930957293496,
      "y": 3954.4100911974892,
      "width": 1489.119873046875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
