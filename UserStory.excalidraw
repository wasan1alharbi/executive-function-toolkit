    {
      "id": "VH0-6JeOSSznSunl8jxok",
      "type": "text",
      "x": -1325.9862174643222,
      "y": 4461.846178230634,
      "width": 1460.919677734375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
