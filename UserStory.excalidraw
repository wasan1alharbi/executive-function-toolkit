    },
    {
      "id": "KU8P5T0y5TtbFuYoB-45R",
      "type": "text",
      "x": -3411.812188471361,
      "y": 5408.220493335457,
      "width": 1362.181941000716,
      "height": 245.7210796686487,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5a",
